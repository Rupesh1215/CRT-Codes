import java.io.*;
import java.util.*;

public class Main {

    public static void main(String[] args) {
        /* Enter your code here. Read input from STDIN. Print output to STDOUT. Your class should be named Main. */
        Scanner s = new Scanner(System.in);
        int n = s.nextInt();
        int count = 0;
        for(int i = 1; i <= n; i++){
            for(int j = 1; i * j <= n; j++){
                if(i * j <= n && i <= j){
                    count++;
                }
            }
        }
        
        System.out.println(count);
    }
}
