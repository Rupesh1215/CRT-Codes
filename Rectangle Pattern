import java.io.*;
import java.util.*;

public class Main {

    public static void main(String[] args) {
        /* Enter your code here. Read input from STDIN. Print output to STDOUT. Your class should be named Main. */
        Scanner s = new Scanner(System.in);
        int n = s.nextInt();
        int count = 0;
        for(int i = 0; i < n; i++){
            count++;
            int num = n; 
            for(int j = num; j >= 1; j--){
            if(num == count){
                System.out.print("*");
            }
            else{
                System.out.print(num);
            }
            num = num - 1;
            }
            System.out.println();
        }
    }
}
